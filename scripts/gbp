#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
APP_PY="${GBP_APP_PY:-$SCRIPT_DIR/git_branch_pane.py}"
STATE_DIR="${GBP_STATE_DIR:-$HOME/.local/state/git-branch-pane}"
PID_FILE="$STATE_DIR/server.pid"
URL_FILE="$STATE_DIR/server.url"
REPO_FILE="$STATE_DIR/server.repo"
LOG_FILE="$STATE_DIR/server.log"

running_pid() {
  if [ -f "$PID_FILE" ]; then
    pid=$(cat "$PID_FILE" 2>/dev/null || true)
    case "$pid" in
      ""|*[!0-9]*) return 1 ;;
    esac
    if kill -0 "$pid" 2>/dev/null; then
      printf '%s\n' "$pid"
      return 0
    fi
  fi
  return 1
}

stop_server() {
  if pid=$(running_pid); then
    kill "$pid" 2>/dev/null || true
    waits=0
    while kill -0 "$pid" 2>/dev/null && [ "$waits" -lt 3 ]; do
      sleep 1
      waits=$((waits + 1))
    done
    if kill -0 "$pid" 2>/dev/null; then
      kill -KILL "$pid" 2>/dev/null || true
    fi
    echo "Stopped Git Branch Pane ($pid)."
  else
    echo "Git Branch Pane is not running."
  fi
  rm -f "$PID_FILE"
}

status_server() {
  if pid=$(running_pid); then
    echo "Git Branch Pane is running ($pid)."
    [ -f "$URL_FILE" ] && sed 's/^/URL: /' "$URL_FILE"
    [ -f "$REPO_FILE" ] && sed 's/^/Repo: /' "$REPO_FILE"
    echo "Log: $LOG_FILE"
    exit 0
  fi
  echo "Git Branch Pane is not running."
  [ -f "$URL_FILE" ] && sed 's/^/Last URL: /' "$URL_FILE"
  echo "Log: $LOG_FILE"
  exit 1
}

MODE=daemon
case "${1:-}" in
  --daemon)
    MODE=daemon
    shift
    ;;
  --foreground)
    MODE=foreground
    shift
    ;;
  --stop)
    stop_server
    exit 0
    ;;
  --status)
    status_server
    ;;
esac

if [ "${GBP_DAEMON:-1}" = "0" ]; then
  MODE=foreground
fi

if [ "$#" -eq 0 ]; then
  set -- .
fi

EXTRA_OPEN=
if [ "${GBP_OPEN:-1}" != "0" ] && [ -z "${SSH_CONNECTION:-}" ]; then
  EXTRA_OPEN=--open
fi

if [ "$MODE" = "foreground" ]; then
  exec python3 "$APP_PY" "$@" $EXTRA_OPEN
fi

start_detached() {
  python3 - "$LOG_FILE" "$PID_FILE" "$APP_PY" "$@" --quiet $EXTRA_OPEN <<'PY'
import os
import sys

log_file, pid_file = sys.argv[1], sys.argv[2]
cmd = [sys.executable, *sys.argv[3:]]
read_fd, write_fd = os.pipe()

first_pid = os.fork()
if first_pid:
    os.close(write_fd)
    data = b""
    while True:
        chunk = os.read(read_fd, 64)
        if not chunk:
            break
        data += chunk
    os.close(read_fd)
    _, status = os.waitpid(first_pid, 0)
    if status != 0:
        sys.exit(1)
    daemon_pid = data.decode("utf-8", "replace").strip()
    if not daemon_pid or not daemon_pid.isdigit():
        sys.exit(1)
    with open(pid_file, "w", encoding="utf-8") as pid_handle:
        pid_handle.write(f"{daemon_pid}\n")
    print(daemon_pid)
    sys.exit(0)

os.close(read_fd)
try:
    os.setsid()
    daemon_pid = os.fork()
    if daemon_pid:
        os.write(write_fd, f"{daemon_pid}\n".encode("utf-8"))
        os.close(write_fd)
        os._exit(0)

    os.close(write_fd)
    stdin_fd = os.open(os.devnull, os.O_RDONLY)
    os.dup2(stdin_fd, 0)
    os.close(stdin_fd)
    log_fd = os.open(log_file, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o644)
    os.dup2(log_fd, 1)
    os.dup2(log_fd, 2)
    os.close(log_fd)
    os.execv(sys.executable, cmd)
except BaseException:
    os._exit(1)
PY
}

mkdir -p "$STATE_DIR"
if running_pid >/dev/null 2>&1; then
  stop_server >/dev/null
fi

rm -f "$PID_FILE" "$URL_FILE"
: > "$LOG_FILE"
case "$1" in
  --*) repo_display=$(pwd) ;;
  *) repo_display=$1 ;;
esac
if repo_root=$(git -C "$repo_display" rev-parse --show-toplevel 2>/dev/null); then
  repo_display=$repo_root
fi
printf '%s\n' "$repo_display" > "$REPO_FILE"

pid=$(start_detached "$@")

waits=0
while [ "$waits" -lt 8 ]; do
  if ! kill -0 "$pid" 2>/dev/null; then
    echo "Git Branch Pane failed to start. Log:" >&2
    sed -n '1,80p' "$LOG_FILE" >&2
    rm -f "$PID_FILE"
    exit 1
  fi
  url=$(sed -n 's/^Git Branch Pane: //p' "$LOG_FILE" | tail -n 1)
  if [ -n "$url" ]; then
    printf '%s\n' "$url" > "$URL_FILE"
    break
  fi
  sleep 1
  waits=$((waits + 1))
done

if [ ! -f "$URL_FILE" ]; then
  echo "Git Branch Pane failed to start. Log:" >&2
  sed -n '1,80p' "$LOG_FILE" >&2
  rm -f "$PID_FILE"
  exit 1
fi

echo "Started Git Branch Pane ($pid)."
if [ -f "$URL_FILE" ]; then
  sed 's/^/URL: /' "$URL_FILE"
else
  echo "URL is still starting. Check: $LOG_FILE"
fi
echo "Stop with: gbp --stop"
