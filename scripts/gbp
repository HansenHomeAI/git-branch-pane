#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
APP_PY="${GBP_APP_PY:-$SCRIPT_DIR/git_branch_pane.py}"
LAUNCHER_PY="${GBP_LAUNCHER_PY:-$SCRIPT_DIR/gbp_launcher.py}"

python_ok() {
  "$1" ${2:+"$2"} -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 9) else 1)' >/dev/null 2>&1
}

find_python() {
  if [ -n "${GBP_PYTHON_EXE:-}" ]; then
    PYTHON_EXE=$GBP_PYTHON_EXE
    PYTHON_ARG=${GBP_PYTHON_ARG:-}
    return 0
  fi
  if command -v python3 >/dev/null 2>&1 && python_ok python3 ""; then
    PYTHON_EXE=python3
    PYTHON_ARG=
    return 0
  fi
  if command -v python >/dev/null 2>&1 && python_ok python ""; then
    PYTHON_EXE=python
    PYTHON_ARG=
    return 0
  fi
  if command -v py >/dev/null 2>&1 && python_ok py "-3"; then
    PYTHON_EXE=py
    PYTHON_ARG=-3
    return 0
  fi
  echo "Missing required Python 3. Install Python 3.9+ or set GBP_PYTHON_EXE." >&2
  exit 1
}

find_python
export GBP_APP_PY APP_PY
exec "$PYTHON_EXE" ${PYTHON_ARG:+"$PYTHON_ARG"} "$LAUNCHER_PY" "$@"
